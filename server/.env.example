# Server environment variables
# Copy this to .env and fill in real values

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL="postgresql://postgres:password@localhost:5432/mathplatform"

# JWT signing secret - must be 32+ random characters
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Invite code required to register a new account
INVITE_CODE="your-invite-code-here"

# Port the server listens on (Railway sets this automatically)
PORT=5000

# URL of the frontend client (used for CORS)
# e.g. https://your-app.vercel.app
CLIENT_URL="http://localhost:5173"

NODE_ENV=development
